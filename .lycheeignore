# Patterns lychee should skip.
# - localhost / loopback URLs are expected in docs (example servers).
^https?://localhost(:\d+)?(/|$)
^https?://127\.0\.0\.1(:\d+)?(/|$)
^https?://0\.0\.0\.0(:\d+)?(/|$)

# - placeholder hostnames in examples.
your-server\.example
byo\.yourdomain\.com
example\.com

# - Discord invite is a placeholder until the server is created (Part I item 6).
discord\.gg/loovie$

# - GHCR image links resolve only once images are published (Phase A.8).
ghcr\.io/looviehq/loovie-server

# - RunPod template deep-link contains a placeholder TEMPLATE_ID until the
#   template is published in RunPod's catalog (Part I item 1).
runpod\.io/console/deploy\?template=<TEMPLATE_ID>

# - HuggingFace model pages return 401 to anonymous CI runners for some
#   repos (especially gated ones). The links resolve fine in a real
#   browser once the user is logged in and has accepted the licence.
^https?://huggingface\.co/

# - apps.apple.com /app/<slug> URL is the canonical App Store deep-link
#   but the slug is not live yet. Will resolve at public launch.
apps\.apple\.com/app/loovie

# - conventionalcommits.org occasionally fails TLS handshake from
#   GitHub-hosted runners. Real URL, flaky from CI only.
^https?://(www\.)?conventionalcommits\.org/

# - GitHub compare links generated by release-please reference tags that
#   may not exist yet on a feature branch (the previous tag in the chain
#   only lands after main is bumped).
github\.com/looviehq/loovie-community/compare/v
