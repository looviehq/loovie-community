# Operational scratch (registry submission checklists, draft PR bodies,
# etc.) — intentionally local. Lives at repo root, NOT inside loovie-mcp/
# so Claude Code's plugin cache never copies these to user machines.
_internal/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual envs
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# uv
.uv-cache/

# Testing
.tox/
.nox/
.coverage
.coverage.*
.cache
.pytest_cache/
htmlcov/
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/

# Type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# OS
.DS_Store
Thumbs.db

# IDEs
.idea/
.vscode/
*.swp
*.swo
*~

